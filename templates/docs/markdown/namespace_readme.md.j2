{%- import 'stability.j2' as stability -%}
{%- import 'notes.j2' as notes -%}
{%- import 'enum_macros.j2' as enums -%}
{%- import 'attribute_macros.j2' as attrs -%}
{%- import 'examples_macros.j2' as examples -%}
{%- import 'links.j2' as links -%}
{%- import 'titles.j2' as titles -%}
{%- set ns = ctx.root_namespace -%}
{%- set spans_url = links.registry_page_url(ns, "spans.md") | trim -%}
{%- set metrics_url = links.registry_page_url(ns, "metrics.md") | trim -%}
{%- set events_url = links.registry_page_url(ns, "events.md") | trim -%}
{%- set entities_url = links.registry_page_url(ns, "entities.md") | trim -%}
{#- Each signal type is split into current and deprecated: the deprecated ones are
   pulled out of their section into a single "Deprecated" section at the bottom.
   A `generate_*_registry` param turned off empties the list, so an empty list is
   the only "should this section render?" check the body needs. -#}
{%- set all_entities = ctx.entities if params.generate_entity_registry else [] -%}
{%- set all_events = ctx.events if params.generate_event_registry else [] -%}
{%- set all_metrics = ctx.metrics if params.generate_metric_registry else [] -%}
{%- set all_spans = ctx.spans if params.generate_span_registry else [] -%}
{%- set all_attributes = ctx.attributes if params.generate_attribute_registry else [] -%}
{%- set entities = all_entities | rejectattr("deprecated") | list -%}
{%- set events = all_events | rejectattr("deprecated") | list -%}
{%- set metrics = all_metrics | rejectattr("deprecated") | list -%}
{%- set spans = all_spans | rejectattr("deprecated") | list -%}
{%- set attributes = all_attributes | rejectattr("deprecated") | list -%}
{%- set dep_entities = all_entities | selectattr("deprecated") | list -%}
{%- set dep_events = all_events | selectattr("deprecated") | list -%}
{%- set dep_metrics = all_metrics | selectattr("deprecated") | list -%}
{%- set dep_spans = all_spans | selectattr("deprecated") | list -%}
{%- set dep_attributes = all_attributes | selectattr("deprecated") | list -%}
{%- set has_deprecated = dep_entities or dep_events or dep_metrics or dep_spans or dep_attributes -%}
{#- `id_attr` is the field holding the signal id: `type` for spans and entities,
   `name` for metrics and events. -#}
{%- macro signal_table(signals, id_attr, page_url, id_header) %}
| {{ id_header }} | Stability | Description |
| --- | --- | --- |
{% for signal in signals | sort(attribute=id_attr) %}| [`{{ signal[id_attr] }}`]({{ page_url }}#{{ links.signal_anchor(signal[id_attr]) }}) | {{ stability.badge(signal.stability, signal.deprecated, include_note=false) | trim }} | {{ stability.description(signal) }} |
{% endfor %}
{%- endmacro -%}
{%- macro attribute_table(attributes) %}
| Key | Stability | Value Type | Description | Example Values |
| --- | --- | --- | --- | --- |
{%- for attribute in attributes | sort(attribute="key") %}{% set attr_anchor = attribute.key | kebab_case %}
| <a id="{{ attr_anchor }}">`{{ attribute.key }}`</a> | {{ stability.badge(attribute.stability, attribute.deprecated, attribute.brief, include_note=false) | trim }} | {{ attrs.type(attribute) }} | {{ attrs.description(attribute, notes) }} | {{ examples.format(attribute) }}|
{%- endfor %}
{%- set notes_out = notes.render() | trim %}{% if notes_out %}

{{ notes_out }}
{%- endif %}
{% for enum in attributes | sort(attribute="key") -%}
{%- if enum.type is mapping -%}{{ enums.table({"name": enum.key, "type": enum.type}, notes) }}{% endif -%}
{%- endfor -%}
{%- endmacro -%}
