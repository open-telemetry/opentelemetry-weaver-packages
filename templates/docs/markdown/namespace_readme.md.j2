{%- import 'stability.j2' as stability -%}
{%- import 'notes.j2' as notes -%}
{%- import 'enum_macros.j2' as enums -%}
{%- import 'attribute_macros.j2' as attrs -%}
{%- import 'examples_macros.j2' as examples -%}
{%- import 'links.j2' as links -%}
{%- import 'titles.j2' as titles -%}
{%- import 'signal_table.j2' as table -%}
{%- set ns = ctx.root_namespace -%}
{#- One descriptor per section, in page order. A `generate_*_registry` param
   turned off empties `all`, so an empty list is the only "should this section
   render?" check the body needs. Every section but Attributes links to the
   signal's own page (`page`) and identifies signals by `id_attr`. -#}
{%- set sections = [
  {"title": "Entities", "all": ctx.entities if params.generate_entity_registry else [], "id_attr": "type", "page": "entities.md"},
  {"title": "Events", "all": ctx.events if params.generate_event_registry else [], "id_attr": "name", "page": "events.md"},
  {"title": "Metrics", "all": ctx.metrics if params.generate_metric_registry else [], "id_attr": "name", "page": "metrics.md"},
  {"title": "Spans", "all": ctx.spans if params.generate_span_registry else [], "id_attr": "type", "page": "spans.md"},
  {"title": "Attributes", "all": ctx.attributes if params.generate_attribute_registry else []}
] -%}
{#- Deprecated signals are pulled out of their own section into a single
   "Deprecated" section at the bottom, which repeats the same sections. -#}
{%- set has_deprecated = sections | map(attribute="all") | flatten | selectattr("deprecated") | list -%}
{%- macro attribute_table(attributes) %}
| Key | Stability | Value Type | Description | Example Values |
| --- | --- | --- | --- | --- |
{%- for attribute in attributes | sort(attribute="key") %}
| <a id="{{ attribute.key | kebab_case }}">`{{ attribute.key }}`</a> | {{ stability.badge(attribute, include_note=false) | trim }} | {{ attrs.type(attribute) }} | {{ attrs.description(attribute, notes) }} | {{ examples.format(attribute) }}|
{%- endfor %}
{%- set notes_out = notes.render() | trim %}{% if notes_out %}

{{ notes_out }}
{%- endif %}
{% for enum in attributes | sort(attribute="key") -%}
{%- if enum.type is mapping -%}{{ enums.table({"key": enum.key, "type": enum.type}, notes) }}{% endif -%}
{%- endfor -%}
{%- endmacro -%}
{#- `intro` is the lead-in paragraph of the Attributes section; the deprecated
   half of that section repeats the heading, not the prose. -#}
{%- macro body(section, signals, intro=false) -%}
{%- if section.page %}{{ table.render(signals, section.id_attr, links.registry_page_url(ns, section.page) | trim) }}
{%- else %}
{% if intro %}Attributes defined in the `{{ ns }}` namespace. Application developers are encouraged to reuse existing attributes; see these [naming recommendations]({{ links.naming_recommendations_url() }}) regarding attribute selection and naming for custom use cases.

{% endif %}{{ attribute_table(signals) | trim }}
{% endif -%}
{%- endmacro -%}
<!-- NOTE: THIS FILE IS AUTOGENERATED. DO NOT EDIT BY HAND. -->
<!-- see templates/docs/markdown/namespace_readme.md.j2 -->

# {{ titles.namespace(ns) }}

{% for section in sections %}{% if section.all | rejectattr("deprecated") | list %}- [{{ section.title }}](#{{ section.title | lower }})
{% endif %}{% endfor -%}
{% if has_deprecated %}- [Deprecated](#deprecated)
{% endif -%}
{#- The deprecated sub-sections repeat the section names, so their anchors get the
   `-1` suffix -- but only when the non-deprecated section is also there. -#}
{% for section in sections %}{% if section.all | selectattr("deprecated") | list %}  - [{{ section.title }}](#{{ section.title | lower }}{{ "-1" if section.all | rejectattr("deprecated") | list }})
{% endif %}{% endfor -%}
{% for section in sections %}{% set current = section.all | rejectattr("deprecated") | list %}{% if current %}
## {{ section.title }}
{{ body(section, current, intro=true) }}{% endif %}{% endfor -%}
{%- if has_deprecated %}
## Deprecated
{% for section in sections %}{% set deprecated = section.all | selectattr("deprecated") | list %}{% if deprecated %}
### {{ section.title }}
{{ body(section, deprecated) }}{% endif %}{% endfor -%}
{% endif -%}
