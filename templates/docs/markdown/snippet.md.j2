{# Default snippet template for `<!-- weaver {jq query} -->` blocks. The jq
   filter result is the root template context, so `{{ type }}`, `{{ kind }}`,
   `{{ attributes }}` etc. access fields directly. We rebuild a single object
   from those globals and hand it to the type-specific macros. #}
{%- import 'attribute_table.j2' as at -%}
{%- import 'metric_table.j2' as mt -%}
{%- import 'event_macros.j2' as ev -%}
{%- import 'span_macros.j2' as sp -%}
{%- import 'entity_macros.j2' as entity -%}

{%- set attribute_registry_base_url = (params.registry_base_url ~ "attributes") | trim -%}
{%- set entity_registry_base_url = (params.registry_base_url ~ "entities") | trim -%}
{%- set upstream_docs_base = params.upstream_docs_base | trim -%}
{%- set _kind = kind | default(none) -%}
{%- set _instrument = instrument | default(none) -%}
{%- set _name = name | default(none) -%}
{%- set _attrs = attributes | default([]) -%}
{%- set _stability = stability | default("development") -%}
{%- set _deprecated = deprecated | default(none) -%}
{%- set _brief = brief | default("") -%}
{%- set _note = note | default(none) -%}

<!-- NOTE: THIS TEXT IS AUTOGENERATED. DO NOT EDIT BY HAND. -->
<!-- see templates/docs/markdown/snippet.md.j2 -->
<!-- prettier-ignore-start -->

{% if _kind %}
{%- set span = {"type": (type | default(none)), "id": (id | default(none)), "kind": _kind, "stability": _stability, "deprecated": _deprecated, "brief": _brief, "note": _note, "name": _name, "entity_associations": (entity_associations | default(none))} -%}
{{ sp.header(span, entity_registry_base_url) }}{{ at.generate(_attrs, attribute_registry_base_url, upstream_docs_base, "Attributes") }}
{%- elif _instrument -%}
{%- set metric = {"name": _name, "instrument": _instrument, "unit": (unit | default("")), "stability": _stability, "deprecated": _deprecated, "brief": _brief, "note": _note, "entity_associations": (entity_associations | default([]))} -%}
{{ mt.generate(metric) }}
{{ at.generate(_attrs, attribute_registry_base_url, upstream_docs_base, "Attributes") }}
{%- elif (identity is defined or description is defined) and not _kind and not _instrument -%}
{%- set entity_obj = {"type": (type | default(none)), "stability": _stability, "deprecated": _deprecated, "brief": _brief, "note": _note, "identity": identity | default([]), "description": description | default([])} -%}
{{ entity.header(entity_obj) }}{{ entity.all_attribute_table(entity_obj, attribute_registry_base_url, upstream_docs_base) }}
{%- elif _name and _attrs -%}
{%- set event = {"name": _name, "stability": _stability, "deprecated": _deprecated, "brief": _brief, "note": _note, "entity_associations": (entity_associations | default(none))} -%}
{{ ev.header(event, entity_registry_base_url) }}{{ at.generate(_attrs, attribute_registry_base_url, upstream_docs_base, "Attributes") }}
{%- elif _attrs -%}
{{ at.generate(_attrs, attribute_registry_base_url, upstream_docs_base, "Attributes") }}
{%- endif %}
<!-- prettier-ignore-end -->
<!-- END AUTOGENERATED TEXT -->
