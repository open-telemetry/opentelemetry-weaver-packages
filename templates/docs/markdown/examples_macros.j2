{%- macro escape_multiline_markdown_cell(value) -%}
    {%- if '\n' in value -%}
        {#- Multi-line values (e.g. pretty-printed JSON) can't use real newlines
           or fenced code blocks inside a GFM table cell, so wrap in <pre>, which
           preserves literal indentation (no &nbsp; needed) and renders monospaced.
           Escape HTML first, then turn newlines into <br> so it stays one row. -#}
<pre>{{ value | replace('&', '&amp;') | replace('<', '&lt;') | replace('>', '&gt;') | replace('\n', '<br>') }}</pre>
    {%- else -%}
        `{{- value }}`
    {%- endif -%}
{%- endmacro -%}
{% macro print_examples(examples) %}{%- for e in examples %}{%if loop.first == false %}; {% endif %}{{ escape_multiline_markdown_cell(e | trim) }}{%- endfor %}{% endmacro %}

{#- `item.examples is defined and is not none` rather than a truthiness check:
    a single scalar example may legitimately be falsy (0, false, ""). -#}
{% macro format(item) %}{% if (item.examples is defined and item.examples is not none) or item.type == "enum" or item.type is mapping %}{{formatText(item) | trim }} {% endif %}{% endmacro %}

{% macro formatText(item) %}{%- if item.examples is defined and item.examples is not none %}
{%- if "[]" in item.type and "template" not in item.type %}
{%- if item.examples is sequence %}
{%- if item.examples | select("sequence") | length == 0 %}`{{ item.examples | trim }}`
{%- else %}{{ print_examples(item.examples) }}
{%- endif %}
{%- else %}`[{{ item.examples | trim }}]`
{%- endif %}
{%- elif item.examples is sequence %}{{ print_examples(item.examples) }}
{%- else %}`{{ item.examples | trim }}`
{%- endif %}{%- elif item.type is mapping %}
{%- for e in item.type.members if e.deprecated is not defined or e.deprecated is none %}{% if loop.index0 < 3 %}{% if loop.first == false %}; {% endif %}`{{ e.value | trim }}`{% endif %}{%- endfor %}
{%- elif item.type == "enum" -%}
{%- for e in item.members if e.deprecated is not defined or e.deprecated is none %}{% if loop.index0 < 3 %}{% if loop.first == false %}; {% endif %}`{{ e.value | trim }}`{% endif %}{%- endfor %}
{%- endif %}{% endmacro %}
