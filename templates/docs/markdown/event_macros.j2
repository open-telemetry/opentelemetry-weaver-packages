{# v2 event objects expose: name, brief, note, stability, attributes. #}
{% import 'stability.j2' as stability %}
{% import 'entity_macros.j2' as entities %}
{% macro header(event, entity_registry=none) -%}
**Status:** {{ stability.badge(event.stability, event.deprecated, event.brief) }}

The event name MUST be `{{ event.name }}`.

{{ event.brief | trim }}
{%- if event.note %}

{{ event.note | trim }}{% endif %}
{%- if event.entity_associations is sequence %}

The event SHOULD be associated with one of the following entities:
{% for e in event.entity_associations %}
{%- if entity_registry -%}
- [`{{ e }}`]({{ entities.registry_url(e, entity_registry) }})
{%- else -%}
- `{{ e }}`
{%- endif -%}
{% endfor %}
{% endif %}

{% endmacro %}
