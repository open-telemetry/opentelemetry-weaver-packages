{%- import 'signal_table.j2' as signal_table -%}
{#- Shared layout for the per-signal namespace pages (spans.md, metrics.md,
   events.md, entities.md): an overview table, one section per signal, and the
   deprecated ones grouped under a trailing "Deprecated" heading with their own
   table.

   `id_attr` is the field holding the signal id (`type` for spans and entities,
   `name` for metrics and events) and `section` is a macro `(signal, heading)`
   rendering one signal -- the only part that differs between signal types. -#}
{% macro render(signals, id_attr, section) -%}
{%- set current = signals | rejectattr("deprecated") | list -%}
{%- set deprecated = signals | selectattr("deprecated") | list %}
{{ signal_table.render(current, id_attr) | trim }}
{% for signal in current | sort(attribute=id_attr) %}{{ section(signal, "##") }}{% endfor -%}
{%- if deprecated %}
## Deprecated

{{ signal_table.render(deprecated, id_attr) | trim }}
{% for signal in deprecated | sort(attribute=id_attr) %}{{ section(signal, "###") }}{% endfor -%}
{%- endif -%}
{%- endmacro %}
